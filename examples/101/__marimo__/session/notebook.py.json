      "console": [
        {
          "type": "stream",
          "name": "stdout",
          "text": "./basic\n\u251c\u2500\u2500config.yml\n\u2514\u2500\u2500data.csv\n",
          "mimetype": "text/plain"
        }
      ]
    },
    {
      "id": "bkHC",
      "code_hash": "f866678a5d669e32a6379b27807a8b78",
      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h3 id=\"defining-handlers\">Defining handlers</h3>\n<span class=\"paragraph\">We first need to define two handlers that implement <code>read</code> and <code>write</code> for the two files that make up a configuration.</span></span>"
          }
        }
      ],
      "console": []
