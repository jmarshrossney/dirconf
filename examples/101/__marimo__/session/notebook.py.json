      "console": [
        {
          "type": "stream",
          "name": "stdout",
          "text": "config:\n\t<class 'config_foundry.node.Node'>\n\tconfig.yml\n\t<class '__main__.YamlFileHandler'>\ndata:\n\t<class 'config_foundry.node.Node'>\n\tdata.csv\n\t<class '__main__.CsvFileHandler'>\n",
          "mimetype": "text/plain"
        }
      ]
    },
    {
      "id": "ecfG",
      "code_hash": "b4f62afa65507ae8bef41beb5b6dff15",
