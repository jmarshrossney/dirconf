        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h4 id=\"reading-configurations\">Reading configurations</h4>\n<span class=\"paragraph\">Once a <code>MetaConfig</code> is instantiated, configurations are read into a <code>dict</code> by passing a path to a configuration directory into the <code>read</code> method.</span></span>"
          }
