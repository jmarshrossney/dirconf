    {
      "id": "DnEU",
      "code_hash": "691f4bf030456ef6ec91d6e46a002f64",
      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h4 id=\"accessing-the-nodes\">Accessing the nodes</h4>\n<span class=\"paragraph\">Keep in mind that classes derived from <code>MetaConfig</code> as essentially <a href=\"https://docs.python.org/3/library/dataclasses.html\" rel=\"noopener noreferrer\" target=\"_blank\">dataclasses</a> whose fields are instances of <code>Node</code> (itself a dataclass!).\nAs such, the usual way of accessing dataclass fields applies.</span></span>"
          }
        }
      ],
      "console": []
    },
    {
      "id": "ulZA",
      "code_hash": "da7d033e05d0de4aa75f99e233aa25c7",
